# Docker Compose reads .env automatically when present. These values are optional
# because docker-compose.yml also provides development defaults.

POSTGRES_USER=pennywise
POSTGRES_PASSWORD=pennywise
POSTGRES_DB=pennywise

TEMPORAL_UI_PORT=8233

PENNYWISE_API_PORT=5151
GMAIL_PORT=5170
CIPHER_PORT=5160

RAILWAY_ENVIRONMENT_NAME=local
SERVICE_VERSION=0.0.1
DOMAIN=localhost
JWT_SECRET=dev-jwt-secret-change-me
INTERNAL_AUTH_TOKEN=dev-internal-token-change-me
CALLBACK_URL=http://localhost:5151/api/auth/google/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_APPLICATION_CREDENTIALS_JSON=
PROJECT_ID=
PUBSUB_TOPIC=
SUB_NAME=
NTFY_TOPIC=

# Optional external legacy MLP endpoint. The Docker stack does not run python-mlp.
MLP_SERVICE_URL=

# Required by Cipher. Run Ollama on the host or point this at a reachable
# OpenAI-compatible Ollama endpoint.
OLLAMA_URL=http://host.docker.internal:11434

AGENT_PROVIDER=ollama
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

OTEL_SDK_DISABLED=true
OTEL_TRACES_EXPORTER=none
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_URL=

TEMPORAL_VERSION=1.29.6.1
TEMPORAL_UI_VERSION=2.40.1
